{{!
    @template mod_supervideo/embed_iframe

    Example context (json):
    {
      "elementid": "embed-abc123",
      "videourl": "https://example.com/embed/player/?src=https://example.com/video.m3u8"
    }
}}

<iframe id="{{{elementid}}}"
        style="width: 100%" frameborder="0" webkitallowfullscreen mozallowfullscreen allowfullscreen
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        src="{{{videourl}}}"></iframe>
